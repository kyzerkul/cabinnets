# PostgreSQL — standard connection string, any Postgres host works
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Public site URL (no trailing slash) — used for canonical URLs + OG images
NEXT_PUBLIC_SITE_URL="https://www.cabinets-comptables.fr"

# Email — used for /supprimer-ma-fiche RGPD form (validated in spec 18)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
